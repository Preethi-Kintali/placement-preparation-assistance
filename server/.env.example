# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:8081

# Database
MONGODB_URI=mongodb://USER:PASSWORD@localhost:27017/placeprep?authSource=admin

# Auth
JWT_SECRET=change_this_to_a_long_random_string_at_least_16_chars

# Optional integrations (DO NOT expose to frontend)
YOUTUBE_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# Interview module only (kept separate from shared platform keys)
INTERVIEW_GROQ_API_KEY=
INTERVIEW_GEMINI_API_KEY=

# Study assistant module only (kept separate from shared platform keys)
STUDY_GROQ_API_KEY=
STUDY_GEMINI_API_KEY=
# Optional: override Groq model used by Study Assistant
STUDY_GROQ_MODEL=llama-3.1-8b-instant

# Optional: Email notifications (Gmail app password recommended)
SMTP_ENABLED=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
